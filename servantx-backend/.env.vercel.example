# ServantX backend Vercel mode
ENVIRONMENT=production
DEPLOYMENT_TARGET=vercel
APP_HOST=0.0.0.0
APP_PORT=8000
API_BASE_URL=https://your-backend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGINS=https://your-frontend.vercel.app
LOG_LEVEL=INFO

# Auth / security
JWT_SECRET_KEY=replace-with-strong-random-secret
STORAGE_PRESIGN_SECRET=replace-with-strong-random-secret

# Postgres (Vercel Postgres integration usually injects POSTGRES_URL automatically)
DATABASE_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Force inline processing on Vercel
ENABLE_CELERY_ASYNC=false
FORCE_INLINE_TASKS=true
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Storage
# Use Vercel Blob for uploaded artifacts and generated appeal files.
STORAGE_BACKEND=vercel_blob
BLOB_READ_WRITE_TOKEN=
VERCEL_BLOB_ACCESS=private
VERCEL_BLOB_ADD_RANDOM_SUFFIX=true
STORAGE_PUBLIC_BASE_URL=
STORAGE_ROOT=uploads
DUCKDB_WORKSPACE_ROOT=uploads/workspaces
STORAGE_PRESIGN_TTL_SECONDS=900

# Optional integrations
OPENAI_API_KEY=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=ServantX Contact
SENDGRID_TO_EMAIL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
